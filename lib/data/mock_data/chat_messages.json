    "messages": [
      {"id": 1, "room_id": 1, "sender_id": null, "order_id": null, "type": "bot", "content": "Halo kak Putri! 👋 Selamat datang di Servis AC JasaFix. Ada yang bisa kami bantu? Silakan pilih template pesan di bawah atau ketik langsung pertanyaan Anda. Admin kami akan segera membalas.", "attachment": null, "is_read": true, "created_at": "2026-04-01T13:00:00+07:00"},
      {"id": 2, "room_id": 1, "sender_id": 20, "order_id": null, "type": "template", "content": "Halo, berapa harga untuk cuci AC?", "attachment": null, "is_read": true, "created_at": "2026-04-01T13:01:00+07:00"},
      {"id": 3, "room_id": 1, "sender_id": null, "order_id": null, "type": "bot", "content": "Harga cuci AC kami mulai dari Rp 150.000/unit. Harga bisa berbeda tergantung kondisi dan merek AC. Mohon tunggu sebentar ya kak, admin kami sedang menghubungi Anda! 🙏", "attachment": null, "is_read": true, "created_at": "2026-04-01T13:01:05+07:00"},
      {"id": 4, "room_id": 1, "sender_id": 2, "order_id": null, "type": "text", "content": "Halo kak Putri, saya Agus dari tim Servis AC JasaFix. Betul kak, harga cuci AC Rp 150.000/unit. Mau jadwalkan servis untuk kapan kak?", "attachment": null, "is_read": true, "created_at": "2026-04-01T13:05:00+07:00"},
